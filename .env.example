# Machine Learning Configuration
# Copy this file to .env and update values

# ML Framework Settings
ML_FRAMEWORK=tensorflow
MODEL_PATH=./models/js_analyzer_model.h5
MODEL_VERSION=1.0

# Processing Configuration
PROCESSING_MODE=batch  # Options: batch, stream, both
BATCH_SIZE=32
STREAM_CHUNK_SIZE=1024

# JavaScript Analysis Settings
JS_FILE_EXTENSIONS=.js,.jsx,.ts,.tsx,.mjs
MAX_FILE_SIZE=5242880  # 5MB in bytes
ANALYZE_SECURITY=true
ANALYZE_COMPLEXITY=true
ANALYZE_PATTERNS=true
ANALYZE_CLASSIFICATION=true

# Input/Output Paths
INPUT_DIRECTORY=./data/input
OUTPUT_DIRECTORY=./data/output
RESULTS_FORMAT=json  # Options: json, csv, parquet

# Model Training Settings
TRAINING_DATA_PATH=./data/training
VALIDATION_SPLIT=0.2
TEST_SPLIT=0.1
EPOCHS=50
LEARNING_RATE=0.001

# Performance Settings
USE_GPU=true
NUM_WORKERS=4
RANDOM_SEED=42

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/ml_analyzer.log

# Project Context
PROJECT_NAME=default
PROJECT_TYPE=mixed  # Options: web, mobile, desktop, backend, mixed
ANALYZE_MULTIPLE_PROJECTS=true

# Security & Privacy
REMOVE_SENSITIVE_DATA=true
ANONYMIZE_IDENTIFIERS=false
STORE_RAW_CODE=false
